<Window
    x:Class="IosPhotoImporter.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="iOS Photo Importer">

    <NavigationView x:Name="RootNavigationView" IsBackButtonVisible="Collapsed" PaneDisplayMode="Left">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Device" Tag="device" Icon="Phone" />
            <NavigationViewItem Content="Import Setup" Tag="setup" Icon="Folder" />
            <NavigationViewItem Content="Progress" Tag="progress" Icon="Download" />
            <NavigationViewItem Content="Summary" Tag="summary" Icon="Accept" />
            <NavigationViewItem Content="Settings" Tag="settings" Icon="Setting" />
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
