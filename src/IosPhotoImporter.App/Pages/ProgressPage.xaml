<Page
    x:Class="IosPhotoImporter.App.Pages.ProgressPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Import Progress" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Grid.Row="1" x:Name="CurrentFileText" Text="Waiting for first file..." />

        <ProgressBar Grid.Row="2" x:Name="ProgressBar" Height="20" Minimum="0" Maximum="1" Value="0" />

        <TextBlock Grid.Row="3" x:Name="CountersText" Text="Completed: 0, Skipped: 0, Failed: 0" />
        <TextBlock Grid.Row="4" x:Name="BytesText" Text="Bytes transferred: 0" />

        <InfoBar Grid.Row="5" x:Name="StatusInfoBar" IsOpen="True" Severity="Informational" Message="Import running..." />

        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancelClicked" />
            <Button Content="Resume" Click="OnResumeClicked" />
            <Button Content="Summary" Click="OnSummaryClicked" />
        </StackPanel>
    </Grid>
</Page>
