<Page
    x:Class="IosPhotoImporter.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="8">
            <TextBlock Text="Default Destination Folder" FontWeight="SemiBold" />
            <TextBox x:Name="DefaultDestinationTextBox" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="8">
            <TextBlock Text="Log Verbosity" FontWeight="SemiBold" />
            <ComboBox x:Name="LogVerbosityComboBox" SelectedIndex="0">
                <x:String>Information</x:String>
                <x:String>Warning</x:String>
                <x:String>Error</x:String>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button Content="Save Preferences" Click="OnSaveClicked" />
            <Button Content="Clear Import History" Click="OnClearHistoryClicked" />
        </StackPanel>

        <InfoBar Grid.Row="4" x:Name="StatusInfoBar" IsOpen="False" />
    </Grid>
</Page>
